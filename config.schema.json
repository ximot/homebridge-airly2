{
  "pluginAlias": "Air2",
  "pluginType": "accessory",
  "singular": false,
  "schema": {
    "type": "object",
    "properties": {
      "accessory": {
        "title": "Accessory Identifier",
        "type": "string",
        "const": "Air2",
        "default": "Air2",
        "description": "This must stay as Air2."
      },
      "name": {
        "title": "Accessory Name",
        "type": "string",
        "default": "Airly Air Quality"
      },
      "apikey": {
        "title": "API Key",
        "type": "string",
        "description": "Preferred API key field."
      },
      "latitude": {
        "title": "Latitude",
        "type": "string",
        "required": true
      },
      "longitude": {
        "title": "Longitude",
        "type": "string",
        "required": true
      },
      "maxdistance": {
        "title": "Max Distance (km)",
        "type": "number",
        "default": 3
      },
      "refreshinterval": {
        "title": "Refresh Interval (minutes)",
        "type": "number",
        "default": 15,
        "minimum": 15,
        "description": "How often to fetch data. Minimum 15 minutes (≈100 calls/day API quota)."
      },
      "indextype": {
        "title": "Index Type",
        "type": "string",
        "default": "AIRLY_CAQI",
        "description": "Airly air quality index type. Default: AIRLY_CAQI.",
        "oneOf": [
          { "title": "AIRLY_CAQI (default)", "enum": ["AIRLY_CAQI"] },
          { "title": "AIRLY_AQI (WHO-based)", "enum": ["AIRLY_AQI"] },
          { "title": "US_AQI", "enum": ["US_AQI"] },
          { "title": "CAQI", "enum": ["CAQI"] },
          { "title": "DAQI", "enum": ["DAQI"] },
          { "title": "PIJP (Poland)", "enum": ["PIJP"] }
        ]
      }
    },
    "required": [
      "accessory",
      "apikey",
      "latitude",
      "longitude"
    ]
  }
}
